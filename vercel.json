{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/teacher/app.js",
            "dest": "/public/teacher/app.js"
        },
        {
            "src": "/teacher/style.css",
            "dest": "/public/teacher/style.css"
        },
        {
            "src": "/teacher",
            "dest": "/public/teacher/index.html"
        },
        {
            "src": "/student/app.js",
            "dest": "/public/student/app.js"
        },
        {
            "src": "/student/style.css",
            "dest": "/public/student/style.css"
        },
        {
            "src": "/student",
            "dest": "/public/student/index.html"
        },
        {
            "src": "/",
            "dest": "/public/index.html"
        }
    ]
}